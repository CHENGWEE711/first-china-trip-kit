# Production canonical domain:
NEXT_PUBLIC_SITE_URL=https://www.firstchinatripkit.com

# Optional local test value:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

CONTENT_SOURCE=local

# Newsletter storage, optional until Supabase is connected:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_NEWSLETTER_TABLE=newsletter_subscribers
SUPABASE_CONTACT_TABLE=contact_messages

# Brevo marketing automation. Keep the API key server-side only.
# Create a dedicated list and use its numeric ID as the automation trigger.
BREVO_API_KEY=
BREVO_LIST_ID=

# Optional analytics:
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ANALYTICS_DEBUG=false

# Optional Google Search Console URL-prefix HTML tag verification:
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional WhatsApp contact link. Use a working number-based wa.me link or an
# official WhatsApp short link copied from the app. Username reservations alone
# may not support click-to-chat yet, so an invalid value is hidden safely.
NEXT_PUBLIC_WHATSAPP_URL=

# Optional lightweight monetization:
NEXT_PUBLIC_COFFEE_TIP_URL=
NEXT_PUBLIC_PAYHIP_CHECKLIST_URL=
NEXT_PUBLIC_PAYMENT_APPS_GUIDE_BUY_URL=

# Optional affiliate partner URLs. Leave blank until a verified affiliate URL is issued.
# Empty or invalid values keep the related external buttons disabled.
NEXT_PUBLIC_AFFILIATE_AIRALO_URL=
NEXT_PUBLIC_AFFILIATE_KLOOK_URL=
NEXT_PUBLIC_AFFILIATE_BOOKING_URL=
NEXT_PUBLIC_AFFILIATE_SAFETYWING_URL=

# Optional hard-off switches. A valid URL enables a partner unless its switch is false.
NEXT_PUBLIC_AFFILIATE_AIRALO_ENABLED=true
NEXT_PUBLIC_AFFILIATE_KLOOK_ENABLED=true
NEXT_PUBLIC_AFFILIATE_BOOKING_ENABLED=true
NEXT_PUBLIC_AFFILIATE_SAFETYWING_ENABLED=true
